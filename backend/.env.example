APP_NAME=Primer Mirror API
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

DATABASE_URL=sqlite:///./app/data/app.db

# Admin auth (change these before deploying!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Default pricing coefficients (used to seed the database on first run,
# afterwards edit them via the admin panel / PUT /api/admin/pricing)
DEFAULT_PRICE_PER_M2=25000
DEFAULT_EDGE_PROCESSING_PER_M=1500
DEFAULT_LIGHTING_PER_M=4000
DEFAULT_FRAME_PER_M=3500
DEFAULT_MIN_ORDER_PRICE=15000

# Company contacts
COMPANY_NAME=Primer Mirror
PHONE=+7 747 177 07 61
WHATSAPP=+7 747 177 07 61
INSTAGRAM=https://instagram.com/primer_mirror
KASPI_SHOP_URL=https://kaspi.kz/
